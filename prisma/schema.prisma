// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Sprint 1 — Único rol funcional activo: admin.
// El enum se deja preparado para crecer (empleado, etc.) sin migración de tipo futura.
enum RolUsuario {
  admin

  @@map("rol_usuario")
}

// Negocio / tenant. Toda la data de la app se filtra por pasteleria_id.
model Pasteleria {
  id         String   @id @default(cuid())
  nombre     String
  slug       String   @unique
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usuarios Usuario[]
  clientes Cliente[]

  @@map("pastelerias")
}

// Usuario administrador del sistema (una sola persona en Sprint 1).
model Usuario {
  id            String     @id @default(cuid())
  pasteleria_id String
  email         String     @unique
  nombre        String
  password_hash String
  rol           RolUsuario @default(admin)
  activo        Boolean    @default(true)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  pasteleria Pasteleria @relation(fields: [pasteleria_id], references: [id])

  @@index([pasteleria_id])
  @@map("usuarios")
}

// Clientes de la pastelería. Eliminación lógica vía `activo`.
model Cliente {
  id            String   @id @default(cuid())
  pasteleria_id String
  nombre        String
  telefono      String?
  whatsapp      String?
  email         String?
  direccion     String?
  notas         String?
  activo        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  pasteleria Pasteleria @relation(fields: [pasteleria_id], references: [id])

  // [pasteleria_id, activo] cubre el listado por tenant + soft-delete y, por
  // prefijo izquierdo, las consultas por pasteleria_id (sin índice redundante).
  @@index([pasteleria_id, activo])
  // Búsqueda/orden por nombre dentro del tenant.
  @@index([pasteleria_id, nombre])
  @@map("clientes")
}
