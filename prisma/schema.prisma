// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Sprint 1 — Único rol funcional activo: admin.
// Nuevos roles deberán agregarse en una migración futura aprobada.
enum RolUsuario {
  admin

  @@map("rol_usuario")
}

// Negocio / tenant. Toda la data de la app se filtra por pasteleria_id.
model Pasteleria {
  id         String   @id @default(cuid())
  nombre     String
  slug       String   @unique
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  usuarios     Usuario[]
  clientes     Cliente[]
  pedidos      Pedido[]
  // Back-reference requerido por la relación PedidoItem -> Pasteleria (Prisma
  // exige el lado opuesto). El filtrado por tenant se hace por `pasteleria_id`.
  pedido_items PedidoItem[]

  @@map("pastelerias")
}

// Usuario administrador del sistema.
// Este modelo se usa como modelo de usuario para Better Auth.
// No existe registro público; el admin se crea por setup/seed interno.
model Usuario {
  id             String     @id @default(cuid())
  pasteleria_id  String
  email          String     @unique
  email_verified Boolean    @default(false)
  nombre         String
  image          String?
  rol            RolUsuario @default(admin)
  activo         Boolean    @default(true)
  created_at     DateTime   @default(now())
  updated_at     DateTime   @updatedAt

  pasteleria Pasteleria @relation(fields: [pasteleria_id], references: [id])
  sessions   Session[]
  accounts   Account[]

  @@index([pasteleria_id])
  @@map("usuarios")
}

// --- Tablas de infraestructura de Better Auth ---
// Se dejan con los nombres de campo por defecto del core (camelCase) para no
// introducir una superficie de mapeo frágil; solo la tabla se mapea a plural.

// Sesiones activas emitidas por Better Auth.
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// Credenciales/vínculos de proveedor. En Sprint 1 solo se usa el proveedor
// "credential" (email + password), donde `password` guarda el hash.
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user Usuario @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([providerId, accountId])
  @@map("accounts")
}

// Tokens de verificación temporales que administra Better Auth internamente.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

// Clientes de la pastelería. Eliminación lógica vía `activo`.
model Cliente {
  id            String   @id @default(cuid())
  pasteleria_id String
  nombre        String
  telefono      String?
  whatsapp      String?
  email         String?
  direccion     String?
  notas         String?
  activo        Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  pasteleria Pasteleria @relation(fields: [pasteleria_id], references: [id])
  pedidos    Pedido[]

  // [pasteleria_id, activo] cubre el listado por tenant + soft-delete y, por
  // prefijo izquierdo, las consultas por pasteleria_id (sin índice redundante).
  @@index([pasteleria_id, activo])
  // Búsqueda/orden por nombre dentro del tenant.
  @@index([pasteleria_id, nombre])
  @@map("clientes")
}

// --- Pedidos (Sprint 2, S2-002) ---

// Estado del ciclo de vida de un pedido. Un pedido inicia como `cotizacion`.
enum EstadoPedido {
  cotizacion
  confirmado
  en_preparacion
  listo_para_entregar
  entregado
  cancelado

  @@map("estado_pedido")
}

// Forma de entrega del pedido.
enum TipoEntrega {
  recoger
  domicilio

  @@map("tipo_entrega")
}

// Pedido personalizado de la pastelería. Multi-tenant por `pasteleria_id`.
// Agrupa uno o varios PedidoItem e inicia su ciclo como cotización.
model Pedido {
  id                String       @id @default(cuid())
  pasteleria_id     String
  cliente_id        String
  // El pedido inicia como cotización.
  estado_pedido     EstadoPedido @default(cotizacion)
  fecha_entrega     DateTime
  // Hora en formato "HH:mm"; se modela como texto en el MVP.
  hora_entrega      String
  tipo_entrega      TipoEntrega
  direccion_entrega String?
  // Dinero: Decimal (nunca Float). El total lo calcula el backend en S2-004.
  total             Decimal      @default(0) @db.Decimal(10, 2)
  notas_internas    String?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt

  pasteleria Pasteleria   @relation(fields: [pasteleria_id], references: [id])
  cliente    Cliente      @relation(fields: [cliente_id], references: [id])
  items      PedidoItem[]

  @@index([pasteleria_id])
  @@index([pasteleria_id, cliente_id])
  @@index([pasteleria_id, estado_pedido])
  @@index([pasteleria_id, fecha_entrega])
  // Apoya vistas por estado filtradas/ordenadas por fecha dentro del tenant.
  @@index([pasteleria_id, estado_pedido, fecha_entrega])
  @@map("pedidos")
}

// Renglón de un Pedido. Guarda un snapshot del nombre, la descripción y el
// precio del item al momento del pedido (no depende de un catálogo vivo).
model PedidoItem {
  id              String  @id @default(cuid())
  pasteleria_id   String
  pedido_id       String
  // Preparado para un catálogo futuro: sin FK ni relación en Sprint 2.
  producto_id     String?
  nombre_snapshot String
  descripcion     String?
  cantidad        Int
  // Dinero: Decimal (nunca Float). El subtotal lo calcula el backend en S2-004.
  precio_unitario Decimal @db.Decimal(10, 2)
  subtotal        Decimal @db.Decimal(10, 2)

  pasteleria Pasteleria @relation(fields: [pasteleria_id], references: [id])
  pedido     Pedido     @relation(fields: [pedido_id], references: [id])

  @@index([pasteleria_id])
  @@index([pedido_id])
  @@index([pasteleria_id, pedido_id])
  @@index([producto_id])
  @@map("pedido_items")
}
