# Base de datos PostgreSQL
# No colocar credenciales reales en este archivo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Secreto de autenticación para sesiones/tokens.
# Generar uno real solo en ambiente local/preview/producción y guardarlo en .env o variables del hosting.
AUTH_SECRET="replace-with-secure-random-secret"

# Entorno de ejecución
NODE_ENV="development"