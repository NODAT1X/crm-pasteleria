# Base de datos PostgreSQL
# No colocar credenciales reales en este archivo.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Better Auth — autenticación del administrador.
# Generar un secreto real (>= 32 caracteres) solo en local/preview/producción:
#   npx auth secret   ·   openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-secure-random-secret-at-least-32-chars"

# URL base de la app, usada por Better Auth para cookies/callbacks.
BETTER_AUTH_URL="http://localhost:3000"

# Entorno de ejecución
NODE_ENV="development"

# Setup local del administrador inicial
ADMIN_EMAIL="admin@pasteleria.local"
ADMIN_PASSWORD="replace-with-local-admin-password"
ADMIN_NOMBRE="Administradora"
PASTELERIA_NOMBRE="Mi Pastelería"
PASTELERIA_SLUG="mi-pasteleria"